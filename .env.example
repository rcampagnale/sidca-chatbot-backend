# =========================================================
# SIDCA CHATBOT BACKEND
# =========================================================

PORT=8080

# =========================================================
# MERCADO PAGO - Checkout Pro
# Usar credenciales de prueba en desarrollo.
# Nunca subir tokens reales al repositorio.
# =========================================================
MP_ENV=test
MP_ACCESS_TOKEN_TEST=
MP_ACCESS_TOKEN=
MP_BACK_URL_SUCCESS=sidca://pago-adherente/exito
MP_BACK_URL_PENDING=sidca://pago-adherente/pendiente
MP_BACK_URL_FAILURE=sidca://pago-adherente/error
MP_WEBHOOK_URL=
MP_WEBHOOK_SECRET=

# =========================================================
# FIREBASE / FIRESTORE
# En Cloud Run puede tomar GOOGLE_CLOUD_PROJECT automÃ¡ticamente.
# En local, si querÃ©s probar Firestore REST, podÃ©s usar un token OAuth temporal.
# =========================================================
FIREBASE_PROJECT_ID=sidca-a33f0
GOOGLE_OAUTH_ACCESS_TOKEN=

# =========================================================
# GROQ - respuesta IA con API compatible OpenAI
# =========================================================
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=900

# =========================================================
# FUENTES LOCALES / RAG JSON
# El backend busca primero en estos archivos y reciÃ©n despuÃ©s
# manda a Groq solo los fragmentos encontrados.
# =========================================================
SIDCA_DOCS_LICENCIAS_URL=https://raw.githubusercontent.com/rcampagnale/sidca-chatbot-docs/main/regimen_licencias_docentes.json
SIDCA_DOCS_ESTATUTO_URL=https://raw.githubusercontent.com/rcampagnale/sidca-chatbot-docs/main/texto_provincial_para_firestore.json
SIDCA_DOCS_GENERAL_URL=https://raw.githubusercontent.com/rcampagnale/sidca-chatbot-docs/main/consultas_generales.json

# Opcional: cargar cuando tengas el JSON/PDF convertido de coberturas
SIDCA_DOCS_COBERTURAS_URL=

# CachÃ© de documentos en memoria
LOCAL_RAG_CACHE_TTL_MS=300000

# =========================================================
# OPENAI - solo para transcripciÃ³n de audio si usÃ¡s voz
# No se usa como flujo principal del chatbot.
# =========================================================
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# =========================================================
# VARIABLES ANTERIORES - dejar solo si querÃ©s conservarlas
# para pruebas viejas. El flujo principal ya no usa Agent Builder.
# =========================================================
OPENAI_WORKFLOW_ID=
OPENAI_WORKFLOW_VERSION=
OPENAI_VECTOR_STORE_ID_LICENCIAS=
OPENAI_VECTOR_STORE_ID_ESTATUTO=
OPENAI_VECTOR_STORE_ID_GENERAL=
OPENAI_MODEL=gpt-4.1
SIDCA_DOCS_COBERTURAS_URL=https://raw.githubusercontent.com/rcampagnale/sidca-chatbot-docs/main/decreto_636_coberturas_docentes.json
SIDCA_DOCS_MANIFEST_URL=https://raw.githubusercontent.com/rcampagnale/sidca-chatbot-docs/main/fuentes_chatbot.json

# Firebase Admin / custom token bootstrap
# Usar una sola opción. BASE64 es recomendada para Cloud Run o variables de entorno multilínea.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
